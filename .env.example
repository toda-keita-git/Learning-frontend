# このファイルをコピーして .env を作成し、各自の値を設定してください。
# .env は .gitignore 済みなので、実際の値は公開されません。

# GitHub OAuth App の Client ID
VITE_GITHUB_CLIENT_ID="your_github_oauth_client_id"

# OAuth コールバックURL（OAuth App の設定と一致させる）
VITE_CALLBACK_URL="http://localhost:5173/LearningContent"

# 学習データを保存する対象リポジトリ
VITE_REPO_OWNER="your_github_username"
VITE_REPO_NAME="Learning_Data"

# バックエンド（OAuthコードをトークンに交換するエンドポイント）
VITE_BACKEND_TOKEN_URL="http://127.0.0.1:8080/github"
